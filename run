#!/bin/bash
set -x

MNT=/mnt/sysroot

mkdir -p "$MNT"

echo "== Block devices =="
lsblk -f

echo "== Mounting =="

mountpoint -q "$MNT" || mount /dev/sda1 "$MNT"

echo "Mounted."

mount --bind /dev "$MNT/dev"
mount --bind /proc "$MNT/proc"
mount --bind /sys "$MNT/sys"
mount --bind /run "$MNT/run"

echo "OS inside mounted filesystem:"
cat "$MNT/etc/os-release"

echo "Entering chroot..."

exec chroot "$MNT" /bin/bash
